# ── Database ────────────────────────────────────────────
DATABASE_URL=postgres://sponsoragent:sponsoragent@postgres:5432/sponsoragent

# ── Auth ────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-64-char-random-string

# ── App ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Stripe ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Admin ───────────────────────────────────────────────
ADMIN_SECRET=change-me-admin-secret-64-chars

# ── Email (Polsia proxy) ───────────────────────────────
EMAIL_PROXY_URL=https://mail.polsia.app/api/send
